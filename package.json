{
  "name": "circulab",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide && astro build",
    "compile:paraglide": "node ./project.inlang/compile-paraglide.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "docker:build": "docker build -t circulab .",
    "docker:run": "docker run -p 4321:4321 circulab",
    "docker:stop": "docker stop circulab",
    "machine-translate": "inlang machine translate --project project.inlang"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/node": "^10.0.5",
    "@awesome.me/webawesome": "^3.5.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "astro": "^6.1.7",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@inlang/cli": "^3.0.0",
    "@inlang/paraglide-js": "^2.16.0"
  }
}