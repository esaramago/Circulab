---
import Layout from '@/layouts/Layout.astro'
import { localizeHref } from '@/paraglide/runtime.js'
const docs = Object.values(import.meta.glob('../pages/docs/*.md', { eager: true }))
const orderedDocs = docs.sort((a: any, b: any) => a.frontmatter.order - b.frontmatter.order)
---

<Layout title={Astro.props.title}>
  <h1>{Astro.props.title}</h1>
  <nav>
    <ul>
      {
        orderedDocs.map((doc: any) => (
          <li>
            <a href={localizeHref(doc.url)}>{doc.frontmatter.title || doc.url}</a>
          </li>
        ))
      }
    </ul>
  </nav>
  <section>
    <slot />
  </section>
</Layout>