---
import Layout from '@/layouts/Layout.astro'
import Wizard from '@/components/pages/resources/Wizard.vue'
import Container from '@/components/ui/Container.vue'
import Grid from '@/components/ui/Grid.vue'
import { localizeHref } from '@/paraglide/runtime.js'

const { mode } = Astro.params
const isEdit = mode === 'editar'
const id = Astro.url.searchParams.get('id') || ''
const idQuery = isEdit ? `?id=${id}` : ''

const steps = [
  {
    path: isEdit ? '#' : localizeHref(`/recursos/${mode}`),
    code: 'validation',
    label: 'Validação'
  },
  {
    path: localizeHref(`/recursos/${mode}/descricao${idQuery}`),
    code: 'description',
    label: 'Descrição'
  },
  {
    path: localizeHref(`/recursos/${mode}/localizacao${idQuery}`),
    code: 'location',
    label: 'Localização'
  },
  {
    path: localizeHref(`/recursos/${mode}/contactos${idQuery}`),
    code: 'contacts',
    label: 'Contactos'
  },
  {
    path: localizeHref(`/recursos/${mode}/resumo${idQuery}`),
    code: 'summary',
    label: 'Resumo'
  }
]

const currentStep = Astro.props.currentStep || 'validation'
const title = isEdit ? 'Editar recurso' : 'Adicionar recurso'
const description = isEdit ? 'Edite as informações do recurso.' : 'Adicione um novo recurso para partilhar com a comunidade.'
---

<Layout title={title}>
  <Grid gap="xs" direction="column">
    <h1>{title}</h1>
    <p>{description}</p>
  </Grid>
  <Wizard client:only="vue" steps={steps} currentStep={currentStep} />
  <Container width="xs">
    <slot />
  </Container>
</Layout>

<style scoped>
h1 {
  font-size: var(--wa-font-size-2xl);
  font-weight: var(--wa-font-weight-semibold);
}
p {
  color: var(--wa-color-neutral-70);
}
</style>
