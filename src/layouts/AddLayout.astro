---
import Layout from '@/layouts/Layout.astro'
import Wizard from '@/components/pages/add/Wizard.vue'
import Container from '@/components/ui/Container.vue'
import Grid from '@/components/ui/Grid.vue'

const steps = [
  {
    path: '/dashboard/adicionar',
    code: 'validation',
    label: 'Validação'
  },
  {
    path: '/dashboard/adicionar/descricao',
    code: 'description',
    label: 'Descrição'
  },
  {
    path: '/dashboard/adicionar/localizacao',
    code: 'location',
    label: 'Localização'
  },
  {
    path: '/dashboard/adicionar/resumo',
    code: 'summary',
    label: 'Resumo'
  }
]

const currentStep = Astro.props.currentStep || 'validation'
---

<Layout title="Adicionar">
  <Grid gap="xs" direction="column">
    <h1>Adicionar pin ao mapa</h1>
    <p>Adicione um novo pin ao mapa para partilhar com a comunidade.</p>
  </Grid>
  <Wizard steps={steps} currentStep={currentStep}></Wizard>
  <Container width="xs">
    <slot />
  </Container>
</Layout>

<style scoped>
h1 {
  font-size: var(--wa-font-size-2xl);
  font-weight: var(--wa-font-weight-semibold);
}
p {
  color: var(--wa-color-neutral-70);
}
</style>