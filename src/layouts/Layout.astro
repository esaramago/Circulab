---
import { Font } from 'astro:assets'
import '@awesome.me/webawesome/dist/styles/themes/default.css'
import '@/css/main.css'
import Header from '@/components/Header.astro'
import { ClientRouter } from 'astro:transitions'

interface Props {
	title: string
	fullWidth?: boolean
}

const { title, fullWidth } = Astro.props

---

<!doctype html>
<html lang={Astro.locals.locale}>
	<head>
		<Font cssVariable="--font-roboto" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="initial-scale=1,minimum-scale=1,width=device-width,interactive-widget=resizes-content,viewport-fit=cover" />
    <!-- <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"> -->
    <link rel="manifest" href="/site.webmanifest">
		<meta name="generator" content={Astro.generator} />
		<title>{title} {title ? '|' : ''} Circulab</title>
    <!-- <script is:inline defer src="https://analytics.emanuelsaramago.com/script.js" data-website-id="a128d8c5-ae20-44aa-be85-6e45880b27db"></script> -->

    <ClientRouter />
  </head>
	<body class="wa-dark wa-custom-theme">
    <Header />
    <main class:list={fullWidth ? 'u-width-full' : ''}>
      <slot />
    </main>
	</body>
</html>

<style>
  main {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 120rem;
    margin-inline: auto;
    gap: var(--wa-space-4xl);
    flex: 1;
    padding: var(--wa-space-l) var(--wa-space-xl) var(--wa-space-xl);
    box-sizing: border-box;
    &.u-width-full {
      max-width: none;
      padding-block-start: 0;
      @media (max-width: 767px) {
        padding: 0;
      }
    }
  }
</style>
