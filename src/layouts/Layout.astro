---
import { Font } from 'astro:assets'
import '@awesome.me/webawesome/dist/styles/themes/default.css'
import '@/css/main.css'
import Header from '@/components/Header.astro'
import { ClientRouter } from 'astro:transitions'

interface Props {
	title: string
	marginsMobile?: boolean
}

const { title, marginsMobile = true } = Astro.props

---

<!doctype html>
<html lang={Astro.locals.locale}>
	<head>
		<Font cssVariable="--font-roboto" />
		<meta charset="UTF-8" />
		<meta name="viewport" content="initial-scale=1,minimum-scale=1,width=device-width,interactive-widget=resizes-content,viewport-fit=cover" />
    <!-- <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png"> -->
    <link rel="manifest" href="/site.webmanifest">
		<meta name="generator" content={Astro.generator} />
		<title>{title} {title ? '|' : ''} Circulab</title>
    <!-- <script is:inline defer src="https://analytics.emanuelsaramago.com/script.js" data-website-id="a128d8c5-ae20-44aa-be85-6e45880b27db"></script> -->

    <ClientRouter />
  </head>
	<body class="wa-dark wa-custom-theme">
    <Header />
    <main class:list={marginsMobile ? '' : 'no-margins-mobile'}>
      <slot />
    </main>
	</body>
</html>

<style>
  main {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 0 var(--wa-space-xl) var(--wa-space-xl);
    @media (max-width: 767px) {
      &.no-margins-mobile {
        padding: 0;
      }
    }
  }
</style>
