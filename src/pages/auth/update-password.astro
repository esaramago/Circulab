---
import Layout from '@/layouts/Layout.astro'
import { updatePassword } from '@/actions/auth/updatePassword'
import { checkUser } from '@/actions/auth/checkUser'
import Grid from '@/components/ui/Grid.vue'
import Container from '@/components/ui/Container.vue'
import { createClient } from '@/utils/supabase'
import { localizeHref } from '@/paraglide/runtime.js'
import { localizeRedirectPath } from '@/utils/authRedirect'

const locale = Astro.locals.locale
const loginHref = localizeHref('/login', locale ? { locale } : undefined)
const forgotPasswordHref = localizeHref('/auth/forgot-password', locale ? { locale } : undefined)

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
  response: Astro.response,
})
const { data: auth, error: authError } = await supabase.auth.getUser()

if (authError || !auth.user) {
  return Astro.redirect(`${loginHref}?error=auth`)
}

let errorMessage = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()

  try {
    const { data, error } = await Astro.callAction(updatePassword, formData)
    if (error) {
      throw new Error(error.message || 'Failed to update password')
    }
    if (data?.success) {
      const { data: user } = await Astro.callAction(checkUser, {})
      const hasAccessToDashboard = user?.role_id === 2 || user?.role_id === 3
      if (hasAccessToDashboard) {
        return Astro.redirect(localizeRedirectPath('/dashboard', locale))
      }
      const loginUrl = new URL(loginHref, Astro.url.origin)
      loginUrl.searchParams.set('success', 'password')
      return Astro.redirect(`${loginUrl.pathname}${loginUrl.search}`)
    }
  } catch (error: unknown) {
    errorMessage = error instanceof Error ? error.message : 'Failed to update password'
  }
}
---

<script>
  import '@awesome.me/webawesome/dist/components/button/button.js'
  import '@awesome.me/webawesome/dist/components/input/input.js'
</script>

<Layout title="New password">
  <Container width="xs">
    <h1>Choose a new password</h1>
    {errorMessage && <wa-alert variant="danger">{errorMessage}</wa-alert>}
    <form method="post">
      <Grid gap="s" direction="column">
        <wa-input
          id="password"
          type="password"
          name="password"
          required
          minlength="8"
          label="New password"
          placeholder="New password"
          autofocus
        />
        <wa-input
          id="passwordConfirm"
          type="password"
          name="passwordConfirm"
          required
          minlength="8"
          label="Confirm password"
          placeholder="Confirm password"
        />
        <wa-button variant="primary" type="submit">Update password</wa-button>
      </Grid>
    </form>
    <p>
      <a href={forgotPasswordHref}>Request a new reset link</a>
    </p>
  </Container>
</Layout>
