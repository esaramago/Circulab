---
import Layout from '@/layouts/Layout.astro'
import { actions } from 'astro:actions'
import Grid from '@/components/ui/Grid.vue'
import Container from '@/components/ui/Container.vue'
import { localizeHref } from '@/paraglide/runtime.js'

let errorMessage = ''
let successMessage = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()

  try {
    const { data, error } = await Astro.callAction(actions.resetPassword, formData)
    if (error) {
      throw new Error(error.message || 'Failed to send reset email')
    }
    if (data?.success) {
      successMessage = data.message ?? 'Check your email for a reset link.'
    }
  } catch (error: unknown) {
    errorMessage = error instanceof Error ? error.message : 'Failed to send reset email'
  }
}

const loginHref = localizeHref('/login', Astro.locals.locale ? { locale: Astro.locals.locale } : undefined)
---

<script>
  import '@awesome.me/webawesome/dist/components/button/button.js'
  import '@awesome.me/webawesome/dist/components/input/input.js'
</script>

<Layout title="Reset password">
  <Container width="xs">
    <h1>Reset password</h1>
    <p>Enter your email and we will send you a link to choose a new password.</p>
    {errorMessage && <wa-alert variant="danger">{errorMessage}</wa-alert>}
    {successMessage && <wa-alert variant="success">{successMessage}</wa-alert>}
    {!successMessage && (
      <form method="post">
        <Grid gap="s" direction="column">
          <wa-input
            id="email"
            type="email"
            name="email"
            required
            label="Email"
            placeholder="Email"
            autofocus
          />
          <wa-button variant="primary" type="submit">Send reset link</wa-button>
        </Grid>
      </form>
    )}
    <p>
      <a href={loginHref}>Back to login</a>
    </p>
  </Container>
</Layout>
