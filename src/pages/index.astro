---
import Layout from '@/layouts/Layout.astro'
import { m } from '@/paraglide/messages.js'
import { fetchDB } from '@/utils/fetchDB'

import type { Database } from '@/types/supabase'
const locale = Astro.url.pathname === '/en' || Astro.url.pathname.startsWith('/en/') ? 'en' : 'pt'
const { data: typologies, error } = await fetchDB('typologies').select('*')
---

<Layout title={m.site_title(undefined, { locale })}>
  <p>{m.site_description(undefined, { locale })}</p>
  <p>{m.map(undefined, { locale })}</p>

  {
    typologies ? (
      <ul>
        {typologies.map((item: Database['public']['Tables']['typologies']['Row']) => (
          <li>{item.name}</li>
        ))}
      </ul>
    ) : <p>No typologies found</p>
  }

</Layout>