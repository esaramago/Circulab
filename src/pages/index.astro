---
import Layout from '@/layouts/Layout.astro'
import { m } from '@/paraglide/messages.js'
import Map from '@/components/pages/map/Map.vue'
import { getPins } from '@/actions/resources'

const { data: mapPins } = await Astro.callAction(getPins, {})
---

<Layout title={m.site_title()} fullWidth={true}>
  <Map client:only="vue" pins={mapPins ?? []} />
</Layout>
