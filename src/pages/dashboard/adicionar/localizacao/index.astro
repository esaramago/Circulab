---
import AddLayout from '@/layouts/AddLayout.astro'
import { localizeHref } from '@/paraglide/runtime.js'
import Form from './_Form.vue'

let errorMessage = ''

if (Astro.request.method === 'POST') {
  debugger
  const formData = await Astro.request.formData()
  const location = formData.get('location')
  if (location) {
    return Astro.redirect(localizeHref('/dashboard/adicionar/resumo'))
  } else {
    errorMessage = 'Tem de selecionar uma localização válida para continuar'
  }
}
---

<script>
import '@webawesome/button/button.js'
import '@webawesome/callout/callout.js'
import { localizeHref } from '@/paraglide/runtime.js'

window.addEventListener('submit-form', (event) => {
  const formData = (event as CustomEvent).detail
  window.location.href = localizeHref('/dashboard/adicionar/resumo')
})
window.addEventListener('back', () => {
  window.location.href = localizeHref('/dashboard/adicionar/descricao')
})
</script>
<AddLayout currentStep="location">
  <h2>Localização</h2>
  {errorMessage && <wa-callout variant="danger">{errorMessage}</wa-callout>}
  <Form client:only="vue" />
</AddLayout>