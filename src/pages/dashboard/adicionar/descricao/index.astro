---
import AddLayout from '@/layouts/AddLayout.astro'
import Grid from '@/components/ui/Grid.vue'
import { localizeHref } from '@/paraglide/runtime.js'
import Form from './Form.vue'

let errorMessage = ''
let characterization = ''

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData()
  const characterization = formData.get('characterization')
  if (characterization) {
    return Astro.redirect(localizeHref('/dashboard/adicionar/localizacao'))
  } else {
    errorMessage = 'Tem de introduzir uma caracterização válida para continuar'
  }
}
---

<script>
import '@webawesome/button/button.js'
import '@webawesome/callout/callout.js'
</script>

<AddLayout currentStep="description">
  <h2>Informação base</h2>
  {errorMessage && <wa-callout variant="danger">{errorMessage}</wa-callout>}
  <form method="post">
    <Grid gap="xl" direction="column">
      <Form client:only="vue" />
      <Grid justify="end" gap="s">
        <wa-button variant="brand" appearance="outlined" href={localizeHref('/dashboard/adicionar')}>Voltar</wa-button>
        <wa-button variant="brand" type="submit">Continuar</wa-button>
      </Grid>
    </Grid>
  </form>
</AddLayout>