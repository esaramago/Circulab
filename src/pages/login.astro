---
import Layout from '@/layouts/Layout.astro'
import { actions } from 'astro:actions'
import Grid from '@/components/ui/Grid.vue'
import Container from '@/components/ui/Container.vue'
import { getSafeRedirectPath, localizeRedirectPath } from '@/utils/authRedirect'
import { localizeHref } from '@/paraglide/runtime.js'

let errorMessage = ''
let successMessage = ''
if (Astro.url.searchParams.get('error') === 'auth') {
  errorMessage = 'The sign-in link is invalid or has expired. Please request a new one.'
}
if (Astro.url.searchParams.get('success') === 'password') {
  successMessage = 'Your password has been updated. You can sign in now.'
}
const forgotPasswordHref = localizeHref(
  '/auth/forgot-password',
  Astro.locals.locale ? { locale: Astro.locals.locale } : undefined,
)
const redirectAfterLogin = getSafeRedirectPath(
  Astro.url.searchParams.get('redirect')
)
const ADMIN_EMAIL = import.meta.env.PUBLIC_ADMIN_EMAIL
const ADMIN_PASSWORD = import.meta.env.PUBLIC_ADMIN_PASSWORD

if (Astro.request.method === 'POST') {

  const formData = await Astro.request.formData()

  try {

    const email = formData.get('email')
    const password = formData.get('password')
    const redirectTarget = getSafeRedirectPath(
      (formData.get('redirect') as string) || Astro.url.searchParams.get('redirect')
    )
    if (!email || !password) {
      throw new Error('Email and password are required')
    }

    const { data: loginData, error: loginError } = await Astro.callAction(actions.signIn, formData)
    if (loginError) {
      throw new Error(loginError.message || 'Failed to sign in')
    }

    if (loginData?.success) {

      const hasAccessToDashboard = Astro.locals.user?.role_id === 2 || Astro.locals.user?.role_id === 3
      if (hasAccessToDashboard) {
        return Astro.redirect(localizeRedirectPath(redirectTarget, Astro.locals.locale))
      } else {
        errorMessage = 'You do not have access to the dashboard'
      }
    } else {
      errorMessage = loginData?.message || 'Failed to sign in'
    }

  } catch (error: any) {
    console.error('Login error:', error)
    errorMessage = error.message
  }
}
---

<script>
  import '@awesome.me/webawesome/dist/components/button/button.js'
  import '@awesome.me/webawesome/dist/components/input/input.js'
</script>

<Layout title="Login">
  <Container width="xs">
    <h1>Login</h1>
    {errorMessage && <wa-alert variant="danger">{errorMessage}</wa-alert>}
    {successMessage && <wa-alert variant="success">{successMessage}</wa-alert>}
    <form method="post">
      <input type="hidden" name="redirect" value={redirectAfterLogin} />
      <Grid gap="s" direction="column">
        <wa-input
          id="email"
          type="email"
          name="email"
          required
          label="Email"
          placeholder="Email"
          value={ADMIN_EMAIL}
          autofocus
        />
        <wa-input
          id="password"
          type="password"
          name="password"
          label="Password"
          required
          placeholder="Password"
          value={ADMIN_PASSWORD}
        />
        <wa-button variant="primary" type="submit">Login</wa-button>
        <p>
          <a href={forgotPasswordHref}>Forgot your password?</a>
        </p>
      </Grid>
    </form>
  </Container>
</Layout>
