---
import Layout from '@/layouts/Layout.astro'
import CategoriesManager from '@/components/pages/backoffice/CategoriesManager.vue'
import { fetchDB } from '@/utils/fetchDB'
import { userHasAccess } from '@/utils/userHasAccess'
import { localizeHref } from '@/paraglide/runtime.js'
import Grid from '@/components/ui/Grid.vue'

const user = Astro.locals.user

// Server-side security check
if (!user || !userHasAccess(user, 'backoffice')) {
  return Astro.redirect('/')
}

// Fetch categories and typologies
const { data: categoriesData } = await fetchDB('categories')
  .select('*')
  .order('created_at', { ascending: false })

const { data: typologiesData } = await fetchDB('typologies')
  .select('*')
  .order('name', { ascending: true })

const categories = categoriesData || []
const typologies = typologiesData || []
---

<Layout title="Gestão de Categorias">
  <Grid direction="column">
    <div class="backoffice-page__nav">
      <a class="back-link" href={localizeHref('/backoffice')}>
        <wa-icon name="arrow-left"></wa-icon>
        Voltar ao painel
      </a>
    </div>
    
    <CategoriesManager
      client:only="vue"
      initialCategories={categories}
      typologies={typologies}
    />
  </Grid>
</Layout>

<script>
  import '@awesome.me/webawesome/dist/components/icon/icon.js'
</script>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--wa-space-xs);
    font-size: var(--wa-font-size-s);
    color: var(--wa-color-neutral-600);
    text-decoration: none;
    font-weight: var(--wa-font-weight-semibold);
    transition: color 0.2s ease;

    &:hover {
      color: var(--wa-color-brand-50);
      text-decoration: underline;
    }
  }
</style>
