---
import { m } from '@/paraglide/messages.js'
import { localizeHref, deLocalizeHref } from '@/paraglide/runtime.js'
import Grid from '@/components/ui/Grid.astro'

const path = deLocalizeHref(Astro.url.pathname + Astro.url.search)
const hrefEn = localizeHref(path, { locale: 'en' })
const hrefPt = localizeHref(path, { locale: 'pt' })

---

<header>
  <Grid gap="xl" align="center">
    <a href="/" class="header__logo">
      <span>{m.site_title()}</span>
    </a>
    <nav>
      <ul class="header__nav-list">
        <li>
          <a href={localizeHref('/about')}>{m['about.title']()}</a>
        </li>
        <li>
          <a href={localizeHref('/contacts')}>{m['contacts.title']()}</a>
        </li>
        <li>
          <a href={localizeHref('/docs')}>{m['docs.title']()}</a>
        </li>
      </ul>
    </nav>
  </G>
  <div>
    <a href={hrefEn} class="btn-lang">EN</a>
    <a href={hrefPt} class="btn-lang">PT</a>
  </div>
</header>

<style>
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--wa-space-xl) var(--wa-space-2xl);
  }
  .header__logo {
    display: inline-flex;
    align-items: end;
    gap: var(--wa-space-xs);
    font-size: var(--wa-font-size-l);
    font-weight: var(--wa-font-weight-bold);
    color: var(--wa-color-brand-10);
    text-decoration: none;
    line-height: 1;
    transition: all .2s;

    &:hover {
      color: var(--wa-color-brand-40);
    }
    &::before {
      content: '';
      display: block;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: var(--wa-border-radius-circle);
      background-color: currentColor;
    }
  }

  .header__nav-list {
    display: flex;
    gap: var(--wa-space-m);
    list-style: none;
    padding: 0;
    margin: 0;
    a {
      text-decoration: none;
      font-weight: var(--wa-font-weight-semibold);
      &:hover,
      &.is-active {
        text-decoration: underline;
        color: var(--wa-color-brand-10);
        font-weight: var(--wa-font-weight-bold);
      }
    }
  }
</style>