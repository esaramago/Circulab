---
import type { Spacing } from '@/types/grid'
interface Props {
  gap?: Spacing
  align?: 'start' | 'center' | 'end'
  justify?: 'start' | 'center' | 'end' | 'space-between' | 'space-around' | 'space-evenly'
  wrap?: 'nowrap' | 'wrap'
  direction?: 'row' | 'column'
}

const {
  gap,
  align,
  justify,
  wrap,
  direction,
  ...rest
} = Astro.props
---

<div
  class="l-grid"
  style={`
    ${gap ? `--gap: var(--wa-space-${gap});` : ''}
    ${align ? `--align: ${align};` : ''}
    ${justify ? `--justify: ${justify};` : ''}
    ${wrap ? `--wrap: ${wrap};` : ''}
    ${direction ? `--direction: ${direction};` : ''}
  `}
  {...rest}>
  <slot />
</div>

<style>
  .l-grid {
    --gap: var(--spacing-m);
    --align: initial;
    --justify: initial;
    --wrap: initial;
    --direction: initial;
    display: flex;
    flex-direction: var(--direction);
    gap: var(--gap);
    align-items: var(--align);
    justify-content: var(--justify);
    flex-wrap: var(--wrap);
  }
</style>