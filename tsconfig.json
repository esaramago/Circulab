{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@ui/*": [
        "src/components/ui/*"
      ],
      "@webawesome/*": [
        "node_modules/@awesome.me/webawesome/dist/components/*"
      ]
    },
    "jsx": "preserve"
  }
}