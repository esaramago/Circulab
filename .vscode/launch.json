{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "./node_modules/.bin/astro dev",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "(https?://localhost:\\d+/?)",
        "uriFormat": "%s"
      }
    }
  ]
}
