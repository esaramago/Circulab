{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Development server",
      "type": "node-terminal",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "command": "./node_modules/.bin/astro dev",
      "serverReadyAction": {
        "pattern": "- Local:.+(http://.+)",
        "uriFormat": "%s"
      }
    }
  ]
}
